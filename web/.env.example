# Base URL of the Strange Delivery API, including the /api suffix.
# Read at BUILD TIME by Vite (import.meta.env.VITE_API_URL) — it is baked into
# the static bundle, so set it before `npm run build` for each environment.
#
# Local dev:   http://localhost:8001/api   (or 8000, whichever the API serves)
# Production:  https://api.your-domain.com/api
VITE_API_URL=http://localhost:8001/api
